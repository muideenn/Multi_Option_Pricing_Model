# ─────────────────────────────────────────────────────────────────────────────
#  Multi-Company Options Pricing Model — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App settings ─────────────────────────────────────────────────────────────
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=False

# ── Market data ───────────────────────────────────────────────────────────────
# Default ticker to load on startup
DEFAULT_TICKER=DIS

# Historical data window (e.g. 1y, 2y, 5y)
DATA_PERIOD=5y

# ── Financial defaults ────────────────────────────────────────────────────────
# Risk-free rate (as a percentage, e.g. 5.25 for 5.25%)
RISK_FREE_RATE=5.25

# Default option maturity in months
DEFAULT_MATURITY_MONTHS=6

# Default strike as percentage of spot (100 = ATM)
DEFAULT_STRIKE_PCT=100

# ── GARCH settings ────────────────────────────────────────────────────────────
GARCH_P=1
GARCH_Q=1
GARCH_FORECAST_HORIZON=60

# ── Binomial tree ─────────────────────────────────────────────────────────────
# Number of steps for the CRR tree (higher = more accurate, slower)
BINOMIAL_N_STEPS=200

# ── Optional: API keys (if you switch data provider) ─────────────────────────
# ALPHA_VANTAGE_API_KEY=your_key_here
# POLYGON_API_KEY=your_key_here
